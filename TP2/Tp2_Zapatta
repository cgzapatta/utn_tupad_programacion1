#Ejercicio 10
hemisferio = input("Ingrese el hemisferio: ")
mes = int(input("Ingrese el mes: "))
dia = int(input("Ingrese el día: "))

if (mes == 12 and dia >= 21) or (mes <= 3 and (mes < 3 or dia <= 20)):
    estacion_norte = "Invierno"
elif (mes == 3 and dia >= 21) or (mes <= 6 and (mes < 6 or dia <= 20)):
    estacion_norte = "Primavera"
elif (mes == 6 and dia >= 21) or (mes <= 9 and (mes < 9 or dia <= 20)):
    estacion_norte = "Verano"
else:
    estacion_norte = "Otoño"


if hemisferio == "N":
    estacion = estacion_norte
else:
    if estacion_norte == "Invierno":
        estacion = "Verano"
    elif estacion_norte == "Verano":
        estacion = "Invierno"
    elif estacion_norte == "Primavera":
        estacion = "Otoño"
    else:
        estacion = "Primavera"

print("Estás en:", estacion)