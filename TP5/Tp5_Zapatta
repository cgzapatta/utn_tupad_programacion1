    suma = 0
    for j in range(len(matriz_ventas[j])):
        suma += matriz_ventas[i][j]
    if suma > max_ventas:
        max_ventas = suma
        dia_max_ventas = i+1
    print(f"Dia: {i+1}: {suma}")

