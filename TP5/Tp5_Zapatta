# Ejercicio 1

notas = [5, 2, 7, 10, 4, 3, 9, 4, 8, 5]

suma = 0
promedio = 0
nota_max = notas[0]
nota_min = notas[0]

for n in notas:
    suma += n
    if n > nota_max:
        nota_max = n
    if n < nota_min:
        nota_min = n

promedio = suma / len(notas)

print(f"NOTAS: {notas}")
print(f"PROMEDIO: {promedio}")
print(f"NOTA MAXIMA: {nota_max}")
print(f"NOTA MINIMA: {nota_min}")

# Ejercicio 2

lista_productos = []

for x in range (1,6):       
    producto = input("Ingrese un producto: ")
    while not producto.isalpha():
        print("Error. solo puede ingresar letras")
        producto = input("Ingrese producto nuevamente: ")
    lista_productos.append(producto)

lista_productos = sorted(lista_productos)

print("Lista de productos")
for j in lista_productos:
    print(f"{j}")

print("Eliminar un producto de la lista")

producto_eliminar = input("Ingrese producto a eliminar: ")

for x in lista_productos:
    if x == producto_eliminar:
        lista_productos.remove(x)

print("Lista de productos actualizada")
for u in lista_productos:
    print(f"{u}")

