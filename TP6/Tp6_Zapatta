#Ejercicio 4
import math

def calcular_area_circulo(r):
    return math.pi * r**2

def calcular_perimetro_circulo(r):
    return 2 * math.pi * r

radio = float(input("Ingresa el radio del círculo: "))
print(f"Área: {calcular_area_circulo(radio)}")
print(f"Perímetro: {calcular_perimetro_circulo(radio)}")

