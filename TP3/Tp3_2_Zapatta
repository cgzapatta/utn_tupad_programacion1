# Ejercicio 2

usuario_correcto = "alumno"
clave_correcta = "python123"    

intentos = 1

while intentos < 4:
    print(f"Intento: {intentos}/3")
    usuario = input(f"Ingrese usuario: ")
    clave = input("Ingrese clave: ")
    
    if usuario == usuario_correcto and clave == clave_correcta:
        print("Acceso concedido.")
        break
    else:
        print("Error: credenciales inválidas.")
        intentos += 1

if intentos == 4:
    print("Cuenta bloqueada.")
else:
    while True:
        print("1) Estado 2) Cambiar clave 3) Mensaje 4) Salir")
        opcion = input("Opción: ")
        
        if not opcion.isdigit() or int(opcion) < 1 or int(opcion) > 4:
            print("Error: ingrese una opcion correcta.")
            continue
        
        opcion = int(opcion)
        
        if opcion == 1:
            print("Inscripto")
        elif opcion == 2:
            nueva_clave = input("Nueva clave: ")
            if len(nueva_clave) < 6:
                print("Error: mínimo 6 caracteres.")
            else:
                clave_correcta = nueva_clave
                print("Clave actualizada")
        elif opcion == 3:
            print("Estas en la UTN, va a ser dificil pero va a valer la pena!")
        elif opcion == 4:
            print("Programa cerrado")
            break

